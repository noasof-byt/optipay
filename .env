# Microsoft SQL Server — local instance
# Format: sqlserver://HOST:PORT;database=DB;user=USER;password=PASS;encrypt=false;trustServerCertificate=true
# For named instance: sqlserver://localhost\SQLEXPRESS:1433;database=optipay_db;...
# For Windows Auth:   sqlserver://localhost:1433;database=optipay_db;integratedSecurity=true;trustServerCertificate=true
DATABASE_URL="sqlserver://127.0.0.1:49701;database=optipay_db;user=sa;password=strongpasswordforoptipay;encrypt=false;trustServerCertificate=true"

# AES-256-GCM encryption key for card numbers (32 bytes = 64 hex chars)
