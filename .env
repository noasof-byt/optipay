# =============================================================================
# Supabase (PostgreSQL) — replace [ref] and [password] with your project values
#
# How to get these:
#   1. Go to https://supabase.com → your project → Settings → Database
#   2. Under "Connection string", select "URI"
#   3. Connection pooling (port 6543) → DATABASE_URL  (used at runtime via pgBouncer)
#   4. Direct connection (port 5432)  → DIRECT_URL    (used by prisma migrate)
# =============================================================================

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.hxdygtgdiajlytlsjxqs:NoaAyaEldad123@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.hxdygtgdiajlytlsjxqs:NoaAyaEldad123@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

