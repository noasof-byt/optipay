// =============================================================================
// OptiPay — Prisma Schema
// Target DB : Supabase (PostgreSQL)
//
// Migrated from SQL Server. Changes:
//   • datasource provider → "postgresql", added directUrl for Supabase pgBouncer
//   • All @db.NVarChar(Max) → @db.Text
//   • All @db.NVarChar(N)   → @db.VarChar(N)
//   • onDelete/onUpdate NoAction kept — valid in PostgreSQL
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// 1. USERS & IDENTITY
// =============================================================================

model User {
  id                  String    @id @default(uuid())
  email               String    @unique @db.VarChar(320)
  passwordHash        String    @db.Text
  displayName         String?   @db.VarChar(120)
  phoneNumber         String?   @db.VarChar(20)
  avatarUrl           String?   @db.VarChar(500)
  /// "USER" | "ADMIN" | "SUPPORT"
  role                String    @default("USER") @db.VarChar(20)
  isLocked            Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  emailVerified       Boolean   @default(false)
  emailVerifyToken    String?   @unique @db.VarChar(128)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastLoginAt         DateTime?
  isDeleted           Boolean   @default(false)
  deletedAt           DateTime?

  familyGroupOwned    FamilyGroup?
  familyMembership    FamilyGroupMember?
  giftCards           GiftCard[]
  memberships         UserClubMembership[]
  passwordResets      PasswordResetToken[]
  pushSubscriptions   PushSubscription[]
  notifications       Notification[]
  searchHistory       SearchHistory[]
  savingsRecords      SavingsRecord[]
  supportTickets      SupportTicket[]
  ticketReplies       TicketReply[]
  sharedItems         FamilySharedItem[]   @relation("SharedByUser")
  sessions            UserSession[]

  @@index([email])
  @@index([isLocked])
  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique @db.VarChar(128)
  userAgent String?  @db.VarChar(500)
  ipAddress String?  @db.VarChar(45)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([tokenHash])
  @@map("user_sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique @db.VarChar(128)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@map("password_reset_tokens")
}

// =============================================================================
// 2. FAMILY GROUPS
// =============================================================================

model FamilyGroup {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(120)
  ownerId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner       User                @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members     FamilyGroupMember[]
  sharedItems FamilySharedItem[]

  @@map("family_groups")
}

model FamilyGroupMember {
  id            String   @id @default(uuid())
  familyGroupId String
  userId        String   @unique
  /// "OWNER" | "MEMBER"
  role          String   @default("MEMBER") @db.VarChar(20)
  joinedAt      DateTime @default(now())

  familyGroup   FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user          User        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([familyGroupId])
  @@map("family_group_members")
}

model FamilySharedItem {
  id             String   @id @default(uuid())
  familyGroupId  String
  sharedByUserId String
  /// "GIFT_CARD" | "MEMBERSHIP"
  itemType       String   @db.VarChar(20)
  giftCardId     String?  @unique
  membershipId   String?  @unique
  createdAt      DateTime @default(now())

  familyGroup    FamilyGroup         @relation(fields: [familyGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sharedBy       User                @relation("SharedByUser", fields: [sharedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  giftCard       GiftCard?           @relation(fields: [giftCardId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  membership     UserClubMembership? @relation(fields: [membershipId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([familyGroupId])
  @@map("family_shared_items")
}

// =============================================================================
// 3. CLUBS & CONSUMER NETWORKS
// =============================================================================

model Club {
  id                     String    @id @default(uuid())
  name                   String    @unique @db.VarChar(120)
  nameEn                 String?   @db.VarChar(120)
  /// JSON array: ["alias1","alias2"]
  aliases                String    @default("[]") @db.Text
  description            String?   @db.Text
  logoUrl                String?   @db.VarChar(500)
  websiteUrl             String?   @db.VarChar(500)
  baseDiscountPercentage Decimal   @db.Decimal(5, 2)
  isPaidMembership       Boolean   @default(false)
  isActive               Boolean   @default(true)
  lastScrapedAt          DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  memberships       UserClubMembership[]
  storeClubBenefits StoreClubBenefit[]
  clubNetworkRules  ClubNetworkRule[]
  scrapingConfigs   ClubScrapingConfig[]

  @@index([isActive])
  @@map("clubs")
}

model GiftCardNetwork {
  id         String   @id @default(uuid())
  name       String   @unique @db.VarChar(120)
  nameEn     String?  @db.VarChar(120)
  logoUrl    String?  @db.VarChar(500)
  websiteUrl String?  @db.VarChar(500)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  giftCards        GiftCard[]
  acceptingStores  StoreNetwork[]
  clubNetworkRules ClubNetworkRule[]

  @@map("gift_card_networks")
}

model Store {
  id         String   @id @default(uuid())
  name       String   @unique @db.VarChar(120)
  nameEn     String?  @db.VarChar(120)
  logoUrl    String?  @db.VarChar(500)
  websiteUrl String?  @db.VarChar(500)
  isOnline   Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branches          StoreBranch[]
  storeClubBenefits StoreClubBenefit[]
  storeNetworks     StoreNetwork[]
  savingsRecords    SavingsRecord[]

  @@map("stores")
}

model StoreBranch {
  id             String    @id @default(uuid())
  storeId        String
  branchName     String?   @db.VarChar(200)
  city           String?   @db.VarChar(100)
  address        String?   @db.VarChar(500)
  phone          String?   @db.VarChar(20)
  isActive       Boolean   @default(true)
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store          Store     @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([storeId])
  @@index([city])
  @@map("store_branches")
}

model StoreNetwork {
  storeId   String
  networkId String
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  network   GiftCardNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([storeId, networkId])
  @@map("store_networks")
}

model StoreClubBenefit {
  id                 String    @id @default(uuid())
  storeId            String
  clubId             String
  discountPercentage Decimal   @db.Decimal(5, 2)
  maxDiscountAmount  Decimal?  @db.Decimal(10, 2)
  minPurchaseAmount  Decimal?  @db.Decimal(10, 2)
  restrictions       String?   @db.Text
  noDoubleDiscount   Boolean   @default(false)
  validFrom          DateTime?
  validUntil         DateTime?
  isActive           Boolean   @default(true)
  lastVerifiedAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  store              Store    @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  club               Club     @relation(fields: [clubId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([storeId, clubId])
  @@index([storeId])
  @@index([clubId])
  @@map("store_club_benefits")
}

model ClubNetworkRule {
  id              String   @id @default(uuid())
  clubId          String
  networkId       String
  canCombine      Boolean  @default(true)
  ruleDescription String?  @db.Text
  updatedAt       DateTime @updatedAt

  club            Club            @relation(fields: [clubId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  network         GiftCardNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([clubId, networkId])
  @@map("club_network_rules")
}

// =============================================================================
// 4. USER WALLET
// =============================================================================

model GiftCard {
  id                  String    @id @default(uuid())
  userId              String
  networkId           String?
  storeSpecificName   String?   @db.VarChar(120)
  cardNumberEncrypted String    @db.Text
  cardNumberHint      String?   @db.VarChar(4)
  expiryDate          DateTime
  balance             Decimal   @db.Decimal(10, 2)
  currency            String    @default("ILS") @db.VarChar(3)
  isFavorite          Boolean   @default(false)
  isArchived          Boolean   @default(false)
  isSharedWithFamily  Boolean   @default(false)
  archivedAt          DateTime?
  deletedAt           DateTime?
  sortOrder           Int       @default(0)
  usageCount          Int       @default(0)
  lastUsedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  network       GiftCardNetwork? @relation(fields: [networkId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sharedItem    FamilySharedItem?
  usageLogs     CardUsageLog[]
  searchHistory SearchHistory[]

  @@index([userId])
  @@index([expiryDate])
  @@index([isArchived])
  @@index([deletedAt])
  @@map("gift_cards")
}

model UserClubMembership {
  id                  String    @id @default(uuid())
  userId              String
  clubId              String
  membershipNumberEnc String?   @db.Text
  isPaidMembership    Boolean   @default(false)
  monthlyFee          Decimal   @default(0) @db.Decimal(10, 2)
  joinedAt            DateTime  @default(now())
  expiryDate          DateTime?
  lastUsedAt          DateTime?
  isActive            Boolean   @default(true)
  isSharedWithFamily  Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  club          Club             @relation(fields: [clubId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sharedItem    FamilySharedItem?
  searchHistory SearchHistory[]

  @@unique([userId, clubId])
  @@index([userId])
  @@map("user_club_memberships")
}

model CardUsageLog {
  id             String   @id @default(uuid())
  giftCardId     String
  userId         String
  amountDeducted Decimal  @db.Decimal(10, 2)
  balanceBefore  Decimal  @db.Decimal(10, 2)
  balanceAfter   Decimal  @db.Decimal(10, 2)
  productName    String?  @db.VarChar(500)
  storeId        String?
  /// JSON string: serialized BuyingRoute
  routeSnapshot  String?  @db.Text
  createdAt      DateTime @default(now())

  giftCard       GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([giftCardId])
  @@index([userId])
  @@map("card_usage_logs")
}

// =============================================================================
// 5. PRODUCT SYNONYMS & SEARCH
// =============================================================================

model Product {
  id            String   @id @default(uuid())
  canonicalName String   @db.VarChar(500)
  brand         String?  @db.VarChar(120)
  category      String?  @db.VarChar(120)
  imageUrl      String?  @db.VarChar(500)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  synonyms      ProductSynonym[]

  @@index([brand])
  @@index([category])
  @@map("products")
}

model ProductSynonym {
  id        String   @id @default(uuid())
  productId String
  synonym   String   @unique @db.VarChar(450)
  language  String   @default("he") @db.VarChar(5)
  source    String?  @db.VarChar(20)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([productId])
  @@map("product_synonyms")
}

model SearchHistory {
  id                String   @id @default(uuid())
  userId            String
  query             String   @db.VarChar(500)
  resolvedProductId String?
  resultCount       Int      @default(0)
  productName       String?  @db.VarChar(500)
  storeName         String?  @db.VarChar(200)
  originalPrice     Decimal? @db.Decimal(10, 2)
  finalPrice        Decimal? @db.Decimal(10, 2)
  savingsAmount     Decimal? @db.Decimal(10, 2)
  benefitUsed       String?  @db.VarChar(200)
  giftCardId        String?
  membershipId      String?
  createdAt         DateTime @default(now())

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  giftCard   GiftCard?            @relation(fields: [giftCardId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  membership UserClubMembership?  @relation(fields: [membershipId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([userId])
  @@index([createdAt])
  @@index([giftCardId])
  @@index([membershipId])
  @@map("search_history")
}

// =============================================================================
// 6. SAVINGS RECORDS
// =============================================================================

model SavingsRecord {
  id            String   @id @default(uuid())
  userId        String
  storeId       String?
  productName   String   @db.VarChar(500)
  originalPrice Decimal  @db.Decimal(10, 2)
  finalPrice    Decimal  @db.Decimal(10, 2)
  savedAmount   Decimal  @db.Decimal(10, 2)
  currency      String   @default("ILS") @db.VarChar(3)
  /// JSON string: serialized BuyingRoute[]
  routeSnapshot String   @db.Text
  purchasedAt   DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  store         Store?   @relation(fields: [storeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([purchasedAt])
  @@map("savings_records")
}

// =============================================================================
// 7. BACKGROUND SCRAPING ENGINE
// =============================================================================

model ClubScrapingConfig {
  id             String   @id @default(uuid())
  clubId         String
  targetUrl      String   @db.VarChar(1000)
  /// "playwright" | "cheerio"
  scrapeStrategy String   @default("playwright") @db.VarChar(20)
  /// JSON string: { selectors, xpaths, ... }
  selectorConfig String   @db.Text
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  club           Club          @relation(fields: [clubId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  scrapingJobs   ScrapingJob[]

  @@index([clubId])
  @@map("club_scraping_configs")
}

model ScrapingJob {
  id             String    @id @default(uuid())
  configId       String
  /// "PENDING" | "RUNNING" | "SUCCESS" | "FAILED" | "SKIPPED"
  status         String    @default("PENDING") @db.VarChar(20)
  startedAt      DateTime?
  completedAt    DateTime?
  durationMs     Int?
  errorMessage   String?   @db.Text
  recordsUpdated Int       @default(0)
  createdAt      DateTime  @default(now())

  config         ClubScrapingConfig @relation(fields: [configId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  results        ScrapingResult[]

  @@index([configId])
  @@index([status])
  @@index([createdAt])
  @@map("scraping_jobs")
}

model ScrapingResult {
  id         String   @id @default(uuid())
  jobId      String
  targetUrl  String   @db.VarChar(1000)
  rawHtml    String?  @db.Text
  /// JSON string: structured extraction output
  parsedData String   @db.Text
  isApplied  Boolean  @default(false)
  createdAt  DateTime @default(now())

  job        ScrapingJob @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([jobId])
  @@map("scraping_results")
}

// =============================================================================
// 8. PUSH NOTIFICATIONS
// =============================================================================

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique @db.VarChar(450)
  p256dhKey String   @db.Text
  authKey   String   @db.Text
  userAgent String?  @db.VarChar(500)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@map("push_subscriptions")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  /// "CARD_EXPIRING" | "MEMBERSHIP_UNUSED" | "PROMO" | "SYSTEM"
  type      String    @db.VarChar(30)
  title     String    @db.VarChar(500)
  body      String    @db.Text
  /// JSON string: optional payload
  payload   String?   @db.Text
  isRead    Boolean   @default(false)
  isSent    Boolean   @default(false)
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================================
// 9. SUPPORT SYSTEM
// =============================================================================

model SupportTicket {
  id         String    @id @default(uuid())
  userId     String
  subject    String    @db.VarChar(500)
  /// "OPEN" | "IN_PROGRESS" | "RESOLVED" | "CLOSED"
  status     String    @default("OPEN") @db.VarChar(20)
  priority   Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  user       User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies    TicketReply[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model TicketReply {
  id         String   @id @default(uuid())
  ticketId   String
  authorId   String
  body       String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  author     User          @relation(fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ticketId])
  @@map("ticket_replies")
}
